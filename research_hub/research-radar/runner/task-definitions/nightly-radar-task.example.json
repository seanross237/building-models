{
  "name": "research-radar-nightly",
  "description": "Nightly YouTube, transcript, paper, analysis, and presentation radar for home-base.",
  "repo": "seanross237/building-models",
  "schedule": "0 7 * * *",
  "branch": "main",
  "commit_to": "main",
  "prompt": null,
  "pre_command": "cd research-radar && bash pipelines/nightly-radar.sh",
  "commit_message_template": "chore(research-radar): nightly radar refresh {date}",
  "telegram_on_complete": true,
  "telegram_on_failure": true,
  "enabled": false,
  "max_runtime_minutes": 60,
  "model": "sonnet",
  "max_turns": 50
}
