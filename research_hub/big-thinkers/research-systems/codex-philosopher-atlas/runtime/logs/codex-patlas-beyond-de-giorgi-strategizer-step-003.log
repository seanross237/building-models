set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/common.sh"

ROLE=""
WORKDIR=""
TASK_FILE=""
MODEL=""
SESSION_NAME=""
SENTINEL_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --role)
      ROLE="$2"
      shift 2
      ;;
    --workdir)
      WORKDIR="$2"
      shift 2
      ;;
    --task-file)
      TASK_FILE="$2"
      shift 2
      ;;
    --model)
      MODEL="$2"
      shift 2
      ;;
    --session-name)
      SESSION_NAME="$2"
      shift 2
      ;;
    --sentinel-file)
