wait_for_status_terminal_state() {
  local status_file="$1"
  local timeout_seconds="${2:-7200}"
  local start_epoch
  start_epoch="$(date +%s)"

  while true; do
    if [[ ! -f "$status_file" ]]; then
      sleep 2
      continue
    fi

    local state
    state="$(status_field "$status_file" state)"
    case "$state" in
      done)
        return 0
        ;;
      error)
        return 1
        ;;
    esac

    if (( "$(date +%s)" - start_epoch > timeout_seconds )); then
      return 2
    fi

    sleep 5
  done
}

