# enumerate connected 3-edge 3-uniform hypergraphs on up to 7 vertices
classes={}
for n in range(3,8):
    verts=range(n)
    all_edges=[frozenset(e) for e in itertools.combinations(verts,3)]
    for edges in itertools.combinations(all_edges,3):
        # connected via edge-intersection graph
        adj={i:set() for i in range(3)}
        for i,j in itertools.combinations(range(3),2):
            if edges[i] & edges[j]:
                adj[i].add(j); adj[j].add(i)
        seen={0}; stack=[0]
        while stack:
            i=stack.pop()
            for j in adj[i]:
                if j not in seen:
                    seen.add(j); stack.append(j)
        if len(seen)<3:
            continue
        # exclude repeated identical edges, since combinations distinct already
        key=canon(edges)
        classes.setdefault(key,[]).append(edges)

print('num classes',len(classes))
for key in sorted(classes):
    inters=sorted(len(set(key[i]) & set(key[j])) for i,j in itertools.combinations(range(3),2))
    deg={v:sum(v in e for e in key) for v in sorted(set().union(*key))}
    print(key,'pairs',inters,'support',len(set().union(*key)),'degseq',sorted(deg.values(), reverse=True))
