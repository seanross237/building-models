+
+
+def sign_name(sig):
+    return "+" if sig > 0 else "-"
+
+
+def expand_support(base_modes):
+    modes = dict(base_modes)
+    for label, vector in list(base_modes.items()):
+        modes[f"-{label}"] = negate(vector)
+    return modes
+
+
+def sign_for_label(label, signs):
