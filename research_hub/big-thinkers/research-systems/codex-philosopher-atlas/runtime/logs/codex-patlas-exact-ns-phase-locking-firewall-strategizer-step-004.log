+    e1 = normalize(cross(ref, khat))
+    e2 = normalize(cross(khat, e1))
+    return tuple((e1[i] + 1j * sigma * e2[i]) / math.sqrt(2.0) for i in range(3))
+
+
+def projected_helical_coefficient(target, source_a, source_b, sig_target, sig_a, sig_b):
