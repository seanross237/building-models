+        if abs(coeff) <= TOL:
+            return False
+    return True
+
+
+def new_target_reports(base_modes, signs):
+    active_modes = expand_support(base_modes)
+    support_orbits = {canonical_orbit(vector) for vector in base_modes.values()}
+    reports = []
