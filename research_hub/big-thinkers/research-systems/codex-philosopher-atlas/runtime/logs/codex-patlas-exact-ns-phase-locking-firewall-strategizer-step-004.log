import itertools, time
start=time.time()
perm_cache={m:list(itertools.permutations(range(m))) for m in range(3,8)}
classes={}
for m in range(3,8):
    verts=range(m)
    edges=[tuple(e) for e in itertools.combinations(verts,3)]
    for comb in itertools.combinations(edges,3):
        # support exactly m to avoid duplicates across m
        union=set().union(*map(set,comb))
        if len(union)"'!=m:
            continue
        # connected edge-intersection graph
        adj={i:set() for i in range(3)}
        for i,j in itertools.combinations(range(3),2):
            if set(comb[i]) & set(comb[j]):
                adj[i].add(j); adj[j].add(i)
        seen={0}; stack=[0]
        while stack:
            i=stack.pop()
            for j in adj[i]:
                if j not in seen:
                    seen.add(j); stack.append(j)
        if len(seen)<3:
            continue
        best=None
        verts_sorted=sorted(union)
        idx={v:i for i,v in enumerate(verts_sorted)}
        remapped=[tuple(idx[x] for x in e) for e in comb]
        for perm in perm_cache[m]:
            cand=tuple(sorted(tuple(sorted(perm[x] for x in e)) for e in remapped))
            if best is None or cand<best:
                best=cand
        classes.setdefault(best,0)
        classes[best]+=1
print('"'classes',len(classes),'time',time.time()-start)
for key in sorted(classes):
    inters=sorted(len(set(key[i]) & set(key[j])) for i,j in itertools.combinations(range(3),2))
    deg={v:sum(v in e for e in key) for v in sorted(set().union(*map(set,key)))}
    print(key,'support',len(deg),'pairs',inters,'degseq',sorted(deg.values(),reverse=True),'count',classes[key])
