+
+    out_path = ROOT / "closure_audit.json"
+    out_path.write_text(json.dumps(to_serializable(reports), indent=2))
+
+    summary_lines = []
+    for item in reports:
+        summary_lines.append(f"{item['name']}:")
+        for tau, coeff in item["representative_coefficients"].items():
