  TASK_FILE_ABS="$(abspath "$TASK_FILE")"
  ensure_inside_repo "$TASK_FILE_ABS"
else
  TASK_FILE_ABS=""
fi

if [[ -n "$SENTINEL_FILE" ]]; then
  SENTINEL_FILE_ABS="$(abspath "$SENTINEL_FILE")"
  ensure_inside_repo "$SENTINEL_FILE_ABS"
else
