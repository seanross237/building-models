ensure_inside_repo "$WORKDIR_ABS"

if [[ -n "$TASK_FILE" ]]; then
  TASK_FILE_ABS="$(abspath "$TASK_FILE")"
  ensure_inside_repo "$TASK_FILE_ABS"
else
