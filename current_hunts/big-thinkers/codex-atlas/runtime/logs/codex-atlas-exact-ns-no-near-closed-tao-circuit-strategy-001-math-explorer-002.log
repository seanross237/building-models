+
+def fmt_complex(z: complex) -> str:
+    return f"{z.real:.12f}{z.imag:+.12f}j"
+
+
+def print_internal(name: str, k_by_role: dict[Role, Vec], sigma_by_role: dict[Role, int]) -> None:
