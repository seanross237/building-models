+DESIRED_EXACT: dict[Role, set[tuple[str, str]]] = {
+    "a1": {("a3", "a4")},
+    "a2": {("a1", "a1")},
+    "a3": {("a1", "a1"), ("a2", "a3")},
+    "a4": {("a1", "a3")},
+    "a5": {("a4", "a4")},
