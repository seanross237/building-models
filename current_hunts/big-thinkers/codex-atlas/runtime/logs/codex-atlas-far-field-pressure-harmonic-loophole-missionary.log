}
with open(path, "w", encoding="utf-8") as fh:
    json.dump(payload, fh, indent=2, sort_keys=True)
    fh.write("\n")
PY

  echo "session_name=$SESSION_NAME"
  echo "status_file=$STATUS_FILE"
  echo "result_file=$RESULT_FILE"
  echo "log_file=$LOG_FILE"
