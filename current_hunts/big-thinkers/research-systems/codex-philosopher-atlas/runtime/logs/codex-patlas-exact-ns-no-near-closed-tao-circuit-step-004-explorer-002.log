+#!/usr/bin/env python3
+
+"""Symbolic trigger bound for the F_DT anti-circuit family.
+
+The repository freezes only a family-shape statement for F_DT:
+  - 0 < eta << delta << 1
+  - the desired seed and rotor legs are O(delta)
+  - the tiny trigger starts at |C(0)| = eta
+
+This script records the one explicit consequence we can derive on that frozen
+sheet without inventing a missing helical coefficient table.
+"""
+
+from sympy import Symbol, exp, simplify
+
+
+delta = Symbol("delta", positive=True)
+eta = Symbol("eta", positive=True)
+k_seed = Symbol("K_seed", positive=True)
+k_amp = Symbol("K_amp", positive=True)
+theta_c = Symbol("theta_C", positive=True)
+
+# If |C'| <= K_seed * delta + K_amp * |C| on [0, 1] and |C(0)| = eta,
+# then Gronwall gives the displayed sufficient bound.
+bound_t1 = exp(k_amp) * (eta + k_seed * delta)
+
+# A convenient explicit small-parameter subregime inside eta << delta << 1.
+eta_sub = delta**2
+sub_bound = simplify(bound_t1.subs({eta: eta_sub}))
+delta_star = simplify(1 / (4 * exp(k_amp) * (k_seed + 1)))
+
+print("F_DT trigger upper bound on the frozen normalized window I = [0, 1]")
+print("Assumption: |C'(t)| <= K_seed * delta + K_amp * |C(t)| and |C(0)| = eta.")
+print()
+print("Then:")
+print(f"  |C(t)| <= exp(K_amp) * (eta + K_seed * delta)  for 0 <= t <= 1")
+print()
+print("On the explicit subregime eta <= delta^2 and delta <= 1:")
+print(f"  |C(t)| <= {sub_bound}")
+print()
+print("So the sufficient condition")
+print(f"  delta <= {delta_star}")
+print("implies")
+print("  |C(t)| <= 1/4 = theta_C on I")
+print("and therefore no trigger event occurs on the frozen window:")
+print("  t_trig > 1.")

