   176	def run_probe() -> str:
   177	    lines: list[str] = []
   178	    ordered_parts = orbit_partition((flip_all, swap_inputs))
   179	    orbit_parts = orbit_partition(
   180	        tuple(
   181	            [flip_all]
   182	            + [
   183	                (lambda perm: (lambda sig: permute(sig, perm)))((0, 1, 2)),
   184	                (lambda perm: (lambda sig: permute(sig, perm)))((0, 2, 1)),
   185	                (lambda perm: (lambda sig: permute(sig, perm)))((1, 0, 2)),
   186	                (lambda perm: (lambda sig: permute(sig, perm)))((1, 2, 0)),
   187	                (lambda perm: (lambda sig: permute(sig, perm)))((2, 0, 1)),
   188	                (lambda perm: (lambda sig: permute(sig, perm)))((2, 1, 0)),
   189	            ]
   190	        )
   191	    )
   192	    lines.append("ordered-sign classes (global sign flip + input swap):")
   193	    for part in ordered_parts:
   194	        lines.append("  " + ", ".join(sign_word(sig) for sig in part))
   195	    lines.append("")
   196	    lines.append("orbit-sign classes (global sign flip + full mode permutation):")
   197	    for part in orbit_parts:
   198	        lines.append("  " + ", ".join(sign_word(sig) for sig in part))
   199	    lines.append("")
   200	    for triad in TRIADS:
   201	        p = tuple(float(x) for x in triad.p)
   202	        q = tuple(float(x) for x in triad.q)
   203	        k = tuple(float(x) for x in triad.k)
   204	        area = norm(cross(p, q))
   205	        lines.append(
   206	            f"triad={triad.name} p={triad.p} q={triad.q} k={triad.k} area={area:.6f}"
   207	        )
   208	        mags: dict[tuple[int, int, int], float] = {}
   209	        for sig_k, sig_p, sig_q in itertools.product((1, -1), repeat=3):
   210	            coeff = ordered_coefficient(k, p, q, sig_k, sig_p, sig_q)
   211	            mag = abs(coeff)
   212	            mags[(sig_k, sig_p, sig_q)] = mag
   213	            lines.append(
   214	                "  signs="
   215	                f"{fmt_sign(sig_k)}{fmt_sign(sig_p)}{fmt_sign(sig_q)} "
   216	                f"coeff={coeff.real:+.12f}{coeff.imag:+.12f}j "
   217	                f"|coeff|={mag:.12f}"
   218	            )
   219	        nonzero = sum(m > 1e-10 for m in mags.values())
   220	        lines.append(f"  nonzero_sign_triples={nonzero}/8")

