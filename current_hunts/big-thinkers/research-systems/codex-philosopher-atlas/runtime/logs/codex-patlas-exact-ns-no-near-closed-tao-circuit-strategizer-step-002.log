    state="$(status_field "$status_file" state)"
    case "$state" in
      done)
        return 0
        ;;
      error)
        return 1
        ;;
    esac

    if (( "$(date +%s)" - start_epoch > timeout_seconds )); then
      return 2
    fi

    sleep 5
  done
}

