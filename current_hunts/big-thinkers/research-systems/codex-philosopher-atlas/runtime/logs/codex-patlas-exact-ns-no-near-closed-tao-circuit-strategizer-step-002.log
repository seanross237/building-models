+    L_class(P_n; I)
+      := int_I D_off^class(t) dt / int_I D_on(t) dt,
+
+    L_tot(P_n; I)
+      := int_I D_off(t) dt / int_I D_on(t) dt.
+
+  Near-closed means
+
+    L_tot <= Lambda_tot
+    and
+    L_class <= Lambda_class
