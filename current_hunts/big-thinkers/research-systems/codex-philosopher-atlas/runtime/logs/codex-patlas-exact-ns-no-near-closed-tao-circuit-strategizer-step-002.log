set -euo pipefail

source "$(cd "$(dirname "$0")" && pwd)/common.sh"

ensure_runtime_dirs

STALE_SECONDS="${STALE_SECONDS:-900}"
STATUS_GLOB=("$PATLAS_ROOT/runtime/status/"*.json)

printf "%-42s %-15s %-10s %s\n" "Session" "Role" "Status" "Notes"
