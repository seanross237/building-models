import itertools, math
from collections import defaultdict

ROLES=('a1','a2','a3','a4','a5')
K={
 'a1':(1,0,0),
 'a2':(0,1,0),
 'a3':(0,0,1),
 'a4':(1,1,0),
 'a5':(1,0,1),
}

# Helper functions adapted from earlier audit.
def dot(a,b): return a[0]*b[0]+a[1]*b[1]+a[2]*b[2]
def cross(a,b):
 ax,ay,az=a; bx,by,bz=b
 return (ay*bz-az*by, az*bx-ax*bz, ax*by-ay*bx)
def v_add(a,b): return (a[0]+b[0],a[1]+b[1],a[2]+b[2])
def v_scale(c,a): return (c*a[0],c*a[1],c*a[2])
def norm(a): return math.sqrt(float((a[0]*a[0].conjugate()+a[1]*a[1].conjugate()+a[2]*a[2].conjugate()).real))
def normalize(a):
 n=norm(a)
 return (a[0]/n,a[1]/n,a[2]/n)
def cscale(c,a): return (c*a[0],c*a[1],c*a[2])
def cadd(a,b): return (a[0]+b[0],a[1]+b[1],a[2]+b[2])
def conj(a): return (a[0].conjugate(),a[1].conjugate(),a[2].conjugate())

def helical_basis(k,sigma):
 kh=normalize((complex(k[0]),complex(k[1]),complex(k[2])))
 ref=(0+0j,0+0j,1+0j)
 if norm(cross(kh,ref))<1e-12:
  ref=(0+0j,1+0j,0+0j)
 e1=normalize(cross(ref,kh))
 e2=cross(kh,e1)
 return cscale(1/math.sqrt(2), cadd(e1, cscale(1j*sigma,e2)))

def helical_coeff(k,p,q,sk,sp,sq):
 hk=helical_basis(k,sk); hp=helical_basis(p,sp); hq=helical_basis(q,sq)
 return -0.25*(sp*math.sqrt(sum(x*x for x in p)) - sq*math.sqrt(sum(x*x for x in q))) * dot(cross(hp,hq), conj(hk))

class Mode:
 def __init__(self, vec,sigma,role,conj): self.vec=vec; self.sigma=sigma; self.role=role; self.conj=conj
 @property
 def name(self): return ('bar_' if self.conj else '')+self.role

def support_modes(sig):
 out=[]
 for role in ROLES:
  k=K[role]; s=sig[role]
  out.append(Mode(k,s,role,False))
  out.append(Mode(v_scale(-1,k),-s,role,True))
 return out

def aggregate_internal(sig):
 modes=support_modes(sig)
 out={role: defaultdict(complex) for role in ROLES}
 for target_role in ROLES:
  target=K[target_role]; st=sig[target_role]
  for p in modes:
   for q in modes:
    if v_add(p.vec,q.vec)"'!=target: continue
    coeff=helical_coeff(target,p.vec,q.vec,st,p.sigma,q.sigma)
    if abs(coeff)<1e-12: continue
    out[target_role][(p.name,q.name)] += coeff
 return out

best=[]
for pattern in itertools.product((1,-1), repeat=len(ROLES)):
 sig=dict(zip(ROLES,pattern))
 inter=aggregate_internal(sig)
 c4=inter['"'a4'].get(('a1','a2'),0)+inter['a4'].get(('a2','a1'),0)
 c5=inter['a5'].get(('a1','a3'),0)+inter['a5'].get(('a3','a1'),0)
 if abs(c4)>1e-10 and abs(c5)>1e-10:
  # count other internal terms beyond mirrors of these two triads
  total=sum(len(v) for v in inter.values())
  best.append((abs(abs(c4)-abs(c5)), -min(abs(c4),abs(c5)), total, sig, c4, c5, inter))
best.sort()
for row in best[:10]:
 _,_,total,sig,c4,c5,inter=row
 print('sigma',sig,'c4',c4,'c5',c5,'terms',total)
 for role,terms in inter.items():
  if terms:
   print(role)
   for k,v in sorted(terms.items()):
    print(' ',k,v)
 print('---')
