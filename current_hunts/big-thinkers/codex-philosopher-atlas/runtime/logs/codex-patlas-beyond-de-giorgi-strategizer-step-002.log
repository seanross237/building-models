ROLE=""
WORKDIR=""
MODEL=""
TASK_FILE=""
RESULT_FILE=""
STATUS_FILE=""
SESSION_NAME=""
SENTINEL_FILE=""
LOG_FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --role)
      ROLE="$2"
      shift 2
      ;;
    --workdir)
      WORKDIR="$2"
      shift 2
      ;;
    --model)
      MODEL="$2"
      shift 2
      ;;
    --task-file)
      TASK_FILE="$2"
      shift 2
      ;;
    --result-file)
      RESULT_FILE="$2"
      shift 2
      ;;
    --status-file)
      STATUS_FILE="$2"
      shift 2
      ;;
    --session-name)
      SESSION_NAME="$2"
      shift 2
      ;;
    --sentinel-file)
      SENTINEL_FILE="$2"
      shift 2
      ;;
    --log-file)
