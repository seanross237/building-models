{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ScoreSignalsAnalysis",
  "type": "object",
  "required": [
    "signal_id",
    "summary",
    "sketchability_score",
    "should_promote"
  ],
  "properties": {
    "signal_id": {"type": "string"},
    "summary": {"type": "string"},
    "sketchability_score": {"type": "integer", "minimum": 1, "maximum": 10},
    "comedy_angles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "angle": {"type": "string"},
          "note": {"type": "string"}
        }
      }
    },
    "character_archetypes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "topical_window_hours": {"type": "integer"},
    "should_promote": {"type": "boolean"}
  }
}
