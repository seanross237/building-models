{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResearchRadarAnalysis",
  "type": "object",
  "required": [
    "item_id",
    "topic_slug",
    "item_type",
    "title",
    "source_url",
    "summary",
    "relevance_score",
    "why_it_matters_now",
    "presentation_candidate"
  ],
  "properties": {
    "item_id": {
      "type": "string"
    },
    "topic_slug": {
      "type": "string"
    },
    "item_type": {
      "type": "string",
      "enum": [
        "youtube",
        "paper"
      ]
    },
    "title": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "relevance_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "why_it_matters_now": {
      "type": "string"
    },
    "key_takeaways": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "presentation_candidate": {
      "type": "boolean"
    }
  }
}
